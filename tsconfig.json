{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext",
      "webworker"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noFallthroughCasesInSwitch": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/app/*": ["./apps/web/app/*"],
      "@/components/*": ["./apps/web/components/*"],
      "@/lib/*": ["./lib/*"],
      "@/supabase/*": ["./supabase/*"],
      "@/types/*": ["./types/*"],
      "@/agent-models": ["./agent-models.json"],
      "@/agent-models.json": ["./agent-models.json"]
    }
  },
  "include": [
    "agent-models.json",
    "instrumentation.ts",
    "instrumentation-client.ts",
    "sentry.edge.config.ts",
    "sentry.server.config.ts",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "scripts/**/*.ts",
    "supabase/**/*.ts",
    "supabase/**/*.tsx",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "types/**/*.ts",
    "types/**/*.tsx",
    "seed.ts"
  ],
  "exclude": [
    "node_modules",
    "apps/desktop/dist-electron",
    "apps/ticket-card/dist",
    "apps/ticket-card/node_modules",
    "apps/web/.next",
    "seed.config.ts",
    "public/sw.js",
    "public/swe-worker*.js"
  ]
}
