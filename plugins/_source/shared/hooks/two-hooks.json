{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{hooks.permissionCommand}}"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{hooks.userPromptCommand}}"
          }
        ]
      }
    ]{{#if hooks.stopCommand}},
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "{{hooks.stopCommand}}"
          }
        ]
      }
    ]{{/if}}
  }
}
