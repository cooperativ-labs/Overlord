{
  "expo": {
    "name": "Overlord",
    "slug": "overlord-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "overlord",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cooperativ.overlord",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to authenticate"
      },
      "associatedDomains": [
        "webcredentials:www.ovld.ai"
      ]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090b"
      },
      "package": "com.cooperativ.overlord"
    },
    "plugins": [
      "expo-dev-client",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 100,
          "resizeMode": "contain",
          "backgroundColor": "#09090b"
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow Overlord to use your camera to attach ticket photos.",
          "photosPermission": "Allow Overlord to access your photos to attach ticket images."
        }
      ],
      "expo-document-picker",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#09090b"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "overlord-mobile",
          "organization": "cooperativ-labs"
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
