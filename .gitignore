# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/apps/web/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# env files (can opt-in for commiting if needed)
.env.local
.env.development
.env.production
.env.staging
.env.branch-deploy

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# electron
/dist-electron
/apps/desktop/dist-electron
/release
.electron-cache
/apps/web/.env.prod

# Baked-in production env (generated by scripts/embed-prod-env.mjs)
electron/_prod-env.generated.ts
apps/desktop/electron/_prod-env.generated.ts

# PWA service worker
apps/web/public/sw.js
apps/web/public/sw.js.map
apps/web/public/swe-worker*.js

# Sentry Config File
.sentryclirc

# Sentry Config File
.env.sentry-build-plugin
apps/mobile/ios/sentry.properties
