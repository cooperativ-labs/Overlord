{
  "name": "overlord-cli",
  "version": "5.9.0",
  "description": "Overlord CLI — launch AI agents on tickets from anywhere",
  "type": "module",
  "bin": {
    "overlord": "bin/ovld.mjs",
    "ovld": "bin/ovld.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "plugins/"
  ],
  "scripts": {
    "postinstall": "node bin/_cli/postinstall.mjs || true"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "overlord",
    "ai",
    "agents",
    "cli"
  ],
  "license": "Proprietary",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cooperativ/overlord.git"
  }
}
