{
  "name": "orchestrator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "supabase start",
    "stop": "supabase stop",
    "generate": "node scripts/generate-supabase-types.js local",
    "new": "rm -rf node_modules && yarn cache clean && yarn install && yarn generate",
    "nuke": "yarn install && supabase db reset && supabase start && supabase status && yarn generate",
    "dev": "next dev",
    "build-dev": "yarn sync:template-vars && next build",
    "build-branch": "yarn sync:template-vars && next build",
    "build-staging": "yarn sync:template-vars && next build",
    "build-prod": "yarn sync:template-vars && next build",
    "ngrok": "ngrok http --domain=romantic-pig-living.ngrok-free.app 3000",
    "ngrok:server": "ngrok http --domain=romantic-pig-living.ngrok-free.app 54321",
    "functions-run": "supabase functions serve --env-file ./supabase/.env.local --no-verify-jwt",
    "functions-deploy": "dotenv -e .env.local -- sh -c 'supabase functions deploy --project-ref $SUPABASE_PROJECT_REF'",
    "functions-set-secret": "dotenv -e .env.local -- sh -c 'supabase secrets set --env-file ./supabase/.env.prod --project-ref $SUPABASE_PROJECT_REF'",
    "lint": "yarn run js-lint && yarn run type-check",
    "fix-js-lint": "eslint -c eslint.config.mjs --fix '*.ts' '**/*.tsx' -f table",
    "fix": "yarn run fix-js-lint",
    "js-lint-src": "eslint -c eslint.config.mjs '*.ts' '**/*.tsx' -f table",
    "js-lint-tests": "eslint -c eslint.config.mjs 'tests/**/*.ts' 'tests/**/*.tsx' -f table",
    "fix-js-lint-tests": "eslint -c eslint.config.mjs --fix 'tests/**/*.ts' 'tests/**/*.tsx' -f table",
    "js-lint": "yarn run js-lint-src && yarn run js-lint-tests",
    "type-check": "tsc --noEmit",
    "type-coverage": "type-coverage",
    "test": "jest",
    "test:watch": "jest --watch",
    "seed": "npx tsx seed.ts > supabase/seed.sql",
    "seed:sync": "npx @snaplet/seed sync",
    "sync:template-vars": "npx tsx scripts/sync-template-variables.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "packageManager": "yarn@4.12.0"
}
