{
  "name": "drill",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "supabase start",
    "stop": "supabase stop",
    "generate": "kysely-codegen --dialect=postgres --camel-case --env-file .env.local",
    "generate-deploy": "kysely-codegen --dialect=postgres --camel-case",
    "new": "rm -rf node_modules && yarn cache clean && yarn install && yarn generate",
    "nuke": "yarn install && supabase db reset && supabase start && supabase status && yarn generate",
    "dev": "next dev --turbopack",
    "build-dev": "yarn generate-sitemap && next build --context=development",
    "build-branch": "yarn generate-sitemap && next build --context=branch-deploy",
    "build-staging": "yarn generate-sitemap && next build --context=staging",
    "build-prod": "yarn generate-sitemap && next build --context=production",
    "ngrok": "ngrok http --domain=romantic-pig-living.ngrok-free.app 3000",
    "ngrok:server": "ngrok http --domain=romantic-pig-living.ngrok-free.app 54321",
    "functions-run": "supabase functions serve --env-file ./supabase/.env.local --no-verify-jwt",
    "functions-deploy": "supabase functions deploy --project-ref ${SUPABASE_PROJECT_ID}",
    "functions-set-secret": "supabase secrets set --env-file ./supabase/.env.prod --project-ref ${SUPABASE_PROJECT_ID}",
    "lint": "yarn run js-lint && yarn run style-lint && yarn run type-check",
    "fix": "yarn run fix-js-lint && yarn run fix-style-lint",
    "fix-js-lint": "eslint -c eslint.config.mjs --fix '*.ts' '**/*.tsx' -f table",
    "js-lint-src": "eslint -c eslint.config.mjs '*.ts' '**/*.tsx' -f table",
    "js-lint-tests": "eslint -c eslint.config.mjs 'tests/**/*.ts' 'tests/**/*.tsx' -f table",
    "fix-js-lint-tests": "eslint -c eslint.config.mjs --fix 'tests/**/*.ts' 'tests/**/*.tsx' -f table",
    "js-lint": "yarn run js-lint-src && yarn run js-lint-tests",
    "type-check": "tsc --noEmit",
    "type-coverage": "type-coverage",
    "test": "jest",
    "test:watch": "jest --watch",
    "seed": "npx tsx seed.ts > supabase/seed.sql",
    "sync:template-vars": "npx tsx scripts/sync-template-variables.ts"
  },
  "dependencies": {},
  "devDependencies": {},
  "packageManager": "yarn@4.7.0"
}
