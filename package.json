{
  "name": "overlord",
  "description": "Overlord is a platform for managing AI agent workflows.",
  "author": "Overlord",
  "version": "2.10.0",
  "private": true,
  "main": "dist-electron/main.js",
  "bin": {
    "overlord": "bin/ovld.mjs",
    "ovld": "bin/ovld.mjs"
  },
  "scripts": {
    "start": "supabase start",
    "stop": "supabase stop",
    "sunpeak:ticket-card:dev": "cd mcp-apps/ticket-card && node ../../node_modules/sunpeak/bin/sunpeak.js dev --no-begging",
    "sunpeak:ticket-card:build": "cd mcp-apps/ticket-card && node ../../node_modules/sunpeak/bin/sunpeak.js build",
    "sunpeak:ticket-card:start": "cd mcp-apps/ticket-card && node ../../node_modules/sunpeak/bin/sunpeak.js start",
    "sunpeak:ticket-card:sync": "node scripts/build-ticket-card-app.mjs",
    "sunpeak:ticket-card:build-and-sync": "yarn sunpeak:ticket-card:build && yarn sunpeak:ticket-card:sync",
    "generate": "node scripts/generate-supabase-types.js local",
    "new": "rm -rf node_modules && yarn cache clean && yarn install && yarn generate",
    "nuke": "yarn install && supabase db reset && supabase start && supabase status && yarn generate",
    "dev": "next dev",
    "build": "yarn next build",
    "build-branch": "yarn next build",
    "build-staging": "yarn next build",
    "build-prod": "yarn next build",
    "ngrok": "ngrok http --domain=romantic-pig-living.ngrok-free.app 3000",
    "ngrok:server": "ngrok http --domain=romantic-pig-living.ngrok-free.app 54321",
    "functions-run": "supabase functions serve --env-file ./supabase/.env.local --no-verify-jwt",
    "functions-deploy": "supabase functions deploy --project-ref zitmmhvbilhjjdwgxlfm --no-verify-jwt",
    "functions-set-secret": "supabase secrets set --env-file ./supabase/.env.prod --project-ref zitmmhvbilhjjdwgxlfm",
    "lint": "yarn run js-lint && yarn run type-check",
    "verify:electron-runtime-env": "node scripts/check-electron-runtime-env.mjs",
    "fix-js-lint": "eslint -c eslint.config.mjs --fix '**/*.ts' '**/*.tsx' -f table",
    "fix": "yarn run fix-js-lint",
    "js-lint-src": "eslint -c eslint.config.mjs '**/*.ts' '**/*.tsx' -f table",
    "js-lint-tests": "eslint -c eslint.config.mjs 'tests/**/*.ts' 'tests/**/*.tsx' -f table",
    "fix-js-lint-tests": "eslint -c eslint.config.mjs --fix 'tests/**/*.ts' 'tests/**/*.tsx' -f table",
    "js-lint": "yarn run js-lint-src && yarn run js-lint-tests",
    "type-check": "tsc --noEmit",
    "type-coverage": "type-coverage",
    "test": "jest",
    "test:watch": "jest --watch",
    "seed": "npx tsx seed.ts > supabase/seed.sql",
    "seed:sync": "npx @snaplet/seed sync",
    "sync:template-vars": "npx tsx scripts/sync-template-variables.ts",
    "electron:clean": "rm -rf release dist-electron .next",
    "electron:pack:run": "sh -c \"yarn electron:pack && ./release/mac-arm64/Overlord.app/Contents/MacOS/Overlord 2>&1 | tee /tmp/overlord-electron-prod.log\"",
    "electron:build-main": "tsc -p electron/tsconfig.json",
    "electron:dev": "yarn electron:build-main && concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:copy-static": "cp -r .next/static .next/standalone/.next/static",
    "electron:build": "node scripts/electron-build.mjs",
    "electron:pack": "node scripts/electron-build.mjs --dir",
    "electron:upload:minor": "node scripts/upload-electron-release.mjs --minor",
    "electron:upload:major": "node scripts/upload-electron-release.mjs --major",
    "electron:upload:no-bump": "node scripts/upload-electron-release.mjs --no-bump",
    "electron:upload:retry": "node scripts/retry-upload.mjs",
    "install-agent-permissions": "node scripts/install-agent-permissions.mjs",
    "verify-agent-permissions": "node scripts/verify-agent-permissions.mjs",
    "cli:sync": "cp bin/ovld.mjs packages/overlord-cli/bin/ovld.mjs && cp bin/_cli/*.mjs packages/overlord-cli/bin/_cli/",
    "cli:publish": "yarn cli:sync && cd packages/overlord-cli && npm publish"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sentry/nextjs": "^10.38.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^2.0.1",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.575.0",
    "next": "^16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.18.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "sunpeak": "^0.16.28",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@serwist/turbopack": "^9.5.6",
    "@snaplet/copycat": "^6.0.0",
    "@snaplet/seed": "^0.98.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.2.2",
    "@types/browser-image-compression": "^1.0.13",
    "@types/date-fns": "^2.6.3",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-formatter-table": "^7.32.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-imports-es6-autofix": "^0.6.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "serwist": "^9.5.6",
    "shadcn": "^3.8.4",
    "tailwind": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vercel": "^50.17.1",
    "vite": "^8.0.1",
    "wait-on": "^8.0.3"
  },
  "packageManager": "yarn@4.13.0"
}
