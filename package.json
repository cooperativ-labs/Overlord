{
  "name": "Overlord",
  "description": "Overlord is a platform for managing AI agent workflows.",
  "author": "Overlord",
  "version": "0.2606091312.0",
  "private": true,
  "license": "PolyForm-Strict-1.0.0",
  "main": "apps/desktop/dist-electron/main.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "bin": {
    "overlord": "packages/overlord-cli/bin/ovld.mjs",
    "ovld": "packages/overlord-cli/bin/ovld.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "supabase start",
    "stop": "supabase stop",
    "dev": "yarn workspace @overlord/web dev",
    "dev:web": "yarn workspace @overlord/web dev",
    "dev:desktop": "yarn electron:dev",
    "dev:mobile": "yarn workspace @overlord/mobile dev",
    "mobile:ios": "yarn workspace @overlord/mobile ios",
    "mobile:ios:device": "yarn workspace @overlord/mobile ios:device",
    "mobile:ios:prod": "yarn workspace @overlord/mobile ios:prod",
    "mobile:android": "yarn workspace @overlord/mobile android",
    "mobile:clean": "yarn workspace @overlord/mobile clean",
    "generate": "supabase migration up &&node scripts/generate-supabase-types.js local && yarn fix",
    "new": "rm -rf node_modules && rm -rf /apps/web/.next && yarn cache clean && yarn install",
    "nuke": "yarn install && supabase db reset && supabase start && supabase status && yarn generate",
    "build": "yarn workspace @overlord/web build && yarn sentry:sourcemaps",
    "build:web": "yarn workspace @overlord/web build",
    "build-branch": "yarn workspace @overlord/web build",
    "build-staging": "yarn workspace @overlord/web build",
    "build-prod": "yarn workspace @overlord/web build",
    "ngrok": "ngrok http --domain=romantic-pig-living.ngrok-free.app 3000",
    "ngrok:server": "ngrok http --domain=romantic-pig-living.ngrok-free.app 54321",
    "functions-run": "supabase functions serve --env-file ./supabase/.env.local --no-verify-jwt",
    "functions-deploy": "supabase functions deploy --project-ref zitmmhvbilhjjdwgxlfm --no-verify-jwt",
    "functions-set-secret": "supabase secrets set --env-file ./supabase/.env.prod --project-ref zitmmhvbilhjjdwgxlfm",
    "lint": "yarn run js-lint && yarn run type-check",
    "verify:electron-runtime-env": "node scripts/check-electron-runtime-env.mjs",
    "fix-js-lint": "eslint -c eslint.config.mjs --fix '**/*.ts' '**/*.tsx' -f table",
    "fix": "yarn run fix-js-lint",
    "js-lint-src": "eslint -c eslint.config.mjs '**/*.ts' '**/*.tsx' -f table",
    "js-lint-tests": "eslint -c eslint.config.mjs 'tests/**/*.ts' 'tests/**/*.tsx' -f table",
    "fix-js-lint-tests": "eslint -c eslint.config.mjs --fix 'tests/**/*.ts' 'tests/**/*.tsx' -f table",
    "js-lint": "yarn run js-lint-src && yarn run js-lint-tests",
    "type-check": "yarn type-check:shared && yarn workspace @overlord/web type-check && yarn workspace @overlord/desktop type-check && yarn workspace @overlord/mobile type-check",
    "type-check:shared": "tsc -p tsconfig.json --noEmit",
    "type-coverage": "type-coverage",
    "test": "jest",
    "test:watch": "jest --watch",
    "seed": "npx tsx seed.ts > supabase/seed.sql",
    "seed:sync": "npx @snaplet/seed sync",
    "sync:template-vars": "npx tsx scripts/sync-template-variables.ts",
    "plugins:render": "node scripts/render-agent-plugins.mjs",
    "plugins:check": "node scripts/render-agent-plugins.mjs --check",
    "electron:clean": "rm -rf release apps/desktop/dist-electron apps/web/.next",
    "electron:pack:run": "node scripts/run-packed-electron.mjs",
    "electron:build-main": "node node_modules/esbuild/bin/esbuild apps/desktop/electron/main.ts --bundle --platform=node --target=node20 --outfile=apps/desktop/dist-electron/main.js --external:electron '--external:*.node' --format=cjs --sourcemap && node node_modules/esbuild/bin/esbuild apps/desktop/electron/preload.ts --bundle --platform=node --target=node20 --outfile=apps/desktop/dist-electron/preload.js --external:electron '--external:*.node' --format=cjs --sourcemap",
    "electron:dev:web": "cd apps/web && node ../../node_modules/next/dist/bin/next dev --webpack",
    "electron:dev": "yarn electron:build-main && node node_modules/concurrently/dist/bin/concurrently.js \"yarn electron:dev:web\" \"node node_modules/wait-on/bin/wait-on http://localhost:3000 && node node_modules/electron/cli.js .\"",
    "electron:build-web": "cd apps/web && node ../../node_modules/next/dist/bin/next build",
    "electron:build": "node scripts/electron-build.mjs",
    "electron:build:mac:x64": "node scripts/electron-build.mjs --platform mac --mac-arch x64",
    "electron:build:mac:arm64": "node scripts/electron-build.mjs --platform mac --mac-arch arm64",
    "electron:build:linux:amd64": "node scripts/electron-build.mjs --platform linux --linux-arch amd64",
    "electron:pack": "node scripts/electron-build.mjs --dir",
    "electron:pack:mac:x64": "node scripts/electron-build.mjs --dir --platform mac --mac-arch x64",
    "electron:pack:mac:arm64": "node scripts/electron-build.mjs --dir --platform mac --mac-arch arm64",
    "electron:pack:linux:amd64": "node scripts/electron-build.mjs --dir --platform linux --linux-arch amd64",
    "electron:upload": "node scripts/upload-electron-release.mjs",
    "electron:upload:mac:arm64": "node scripts/upload-electron-release.mjs --target mac:arm64",
    "electron:upload:linux:amd64": "node scripts/upload-electron-release.mjs --target linux:amd64",
    "electron:upload:linux:amd64:no-bump": "node scripts/upload-electron-release.mjs --target linux:amd64 --no-bump",
    "electron:upload:minor": "node scripts/upload-electron-release.mjs --minor",
    "electron:upload:major": "node scripts/upload-electron-release.mjs --major",
    "electron:upload:no-bump": "node scripts/upload-electron-release.mjs --no-bump",
    "install-agent-permissions": "node scripts/install-agent-permissions.mjs",
    "verify-agent-permissions": "node scripts/verify-agent-permissions.mjs",
    "cli:sync": "node scripts/sync-cli-package.mjs",
    "cli:publish": "node scripts/publish-overlord-cli.mjs",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org cooperativ-labs --project overlord-electron apps/desktop/dist-electron && sentry-cli sourcemaps upload --org cooperativ-labs --project overlord-electron apps/desktop/dist-electron"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.46.0",
    "@modelcontextprotocol/ext-apps": "^1.2.2",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@sentry/browser": "^10.52.0",
    "@sentry/cli": "^2",
    "@sentry/core": "^10.52.0",
    "@sentry/electron": "^7.11.0",
    "@sentry/nextjs": "^10.52.0",
    "@sentry/node": "^10.52.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.11",
    "@vercel/analytics": "^2.0.1",
    "@xyflow/react": "^12.10.2",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "date-fns": "^4.2.0",
    "dotenv": "^17.3.1",
    "electron-updater": "6.8.3",
    "jose": "^6.1.3",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron/asar": "^4.1.0",
    "@eslint/js": "^10.0.1",
    "@serwist/turbopack": "^9.5.6",
    "@snaplet/copycat": "^6.0.0",
    "@snaplet/seed": "^0.98.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/vite": "^4.2.2",
    "@types/browser-image-compression": "^1.0.13",
    "@types/d3-force": "^3.0.10",
    "@types/jest": "^30.0.0",
    "@types/katex": "^0.16.8",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.0",
    "eslint-config-next": "^16.1.6",
    "eslint-formatter-table": "^7.32.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sort-imports-es6-autofix": "^0.6.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "serwist": "^9.5.6",
    "shadcn": "^3.8.4",
    "tailwind": "^4.0.0",
    "tailwindcss": "^4.1.18",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.9",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vercel": "^50.17.1",
    "vite": "^8.0.1",
    "wait-on": "^8.0.3"
  },
  "resolutions": {
    "node-abi": "^4.31.0"
  },
  "packageManager": "yarn@4.15.0"
}
